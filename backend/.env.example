# Copy this file to .env and fill in your real API keys.
# The backend loads this automatically via python-dotenv on startup.

# Tavily Search API key — get one at https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API key — get one at https://console.groq.com (free tier available)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key — get one at https://openrouter.ai/keys (free models available)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
